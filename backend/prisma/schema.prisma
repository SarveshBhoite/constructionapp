// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Worker {
  id              String   @id @default(uuid())
  name            String
  phone           String   @unique
  email           String?
  address         String?
  city            String
  state           String
  category        String   // Category ID (e.g., 'mason')
  categoryEn      String   // English Name
  categoryMr      String   // Marathi/Hindi Name
  gender          String?  // 'male' or 'female'
  experienceYears Int
  about           String?
  wages           Float
  wageType        String   // 'HOUR' or 'DAY'
  profileImage    String?
  rating          Float    @default(0)
  isAvailable     Boolean  @default(true)
  isSubscribed    Boolean  @default(false)
  subExpiresAt    DateTime?
  views           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Contractor {
  id           String   @id @default(uuid())
  name         String
  ownerName    String?
  companyName  String?
  phone        String   @unique
  city         String?
  gstin        String?  // GSTIN registration number
  categories   String[] // Array of selected category IDs
  gender       String?  // 'male' or 'female'
  rating       Float    @default(0)
  isSubscribed Boolean  @default(false)
  isApproved   Boolean  @default(false)
  idProof      String?  // Document URL for admin review
  subExpiresAt DateTime?
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Subscription {
  id            String   @id @default(uuid())
  role          String   // 'worker' or 'contractor'
  userId        String?
  contractorId  String?
  razorpayOrderId String
  razorpayPaymentId String?
  amount        Float
  status        String   // 'PENDING', 'SUCCESS', 'FAILED'
  createdAt     DateTime @default(now())
}

model Review {
  id           String   @id @default(uuid())
  workerId     String
  contractorId String
  contractorName String
  rating       Int      // 1-5
  comment      String?
  createdAt    DateTime @default(now())
}

model ContractorReview {
  id           String   @id @default(uuid())
  contractorId String
  workerId     String
  workerName   String
  rating       Int      // 1-5
  comment      String?
  createdAt    DateTime @default(now())
}

model SupportTicket {
  id        String   @id @default(uuid())
  role      String   // 'worker' or 'contractor'
  userId    String
  userName  String
  message   String
  status    String   @default("OPEN") // 'OPEN', 'IN_PROGRESS', 'RESOLVED'
  createdAt DateTime @default(now())
}
